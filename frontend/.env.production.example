# ===========================================================================
# Production FRONTEND environment (Vercel)
# ===========================================================================
# Set in the Vercel dashboard: Project ▸ Settings ▸ Environment Variables
# (scope: Production). NEXT_PUBLIC_* is inlined at BUILD time, so changing it
# requires a redeploy.

# Base URL of your backend = your tunnel URL, no trailing slash.
#   • ngrok static domain (STABLE): set ONCE, never touch it again.
#   • Cloudflare Quick Tunnel (EPHEMERAL): update + redeploy every session, OR
#     for personal testing skip the rebuild and run this in the browser console:
#       localStorage.vfr_api_base_url = "https://<random>.trycloudflare.com"
NEXT_PUBLIC_API_BASE_URL=https://your-name.ngrok-free.app
