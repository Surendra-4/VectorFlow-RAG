# ===========================================================================
# Production FRONTEND environment (Vercel)
# ===========================================================================
# Set this in the Vercel dashboard: Project ▸ Settings ▸ Environment Variables
# (scope: Production, and Preview if you use preview deploys).
#
# NEXT_PUBLIC_* values are inlined at BUILD time, so a change requires a
# redeploy to take effect.

# Base URL of your Render backend — no trailing slash.
NEXT_PUBLIC_API_BASE_URL=https://vectorflow-api.onrender.com

# Tip: users can also override the backend at runtime (no rebuild) by setting
#   localStorage.vfr_api_base_url = "https://your-backend"
# in the browser console — handy for pointing a hosted frontend at a local API.
