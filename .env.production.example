# ===========================================================================
# Production BACKEND environment (Render)
# ===========================================================================
# This file documents the variables to set on your Render web service
# (Settings ▸ Environment). It is a TEMPLATE — never put real secrets in a
# committed file. Copy the keys, set the values in the Render dashboard.
#
# Variable naming: nested settings use the VFR_ prefix and a "__" delimiter,
# e.g. AuthSettings.jwt_secret  ->  VFR_AUTH__JWT_SECRET. See src/config.py.

# ---- Database --------------------------------------------------------------
# Render injects DATABASE_URL automatically when you attach the managed
# Postgres (render.yaml wires it). You normally do NOT set this by hand.
# The app accepts postgres:// / postgresql:// and normalizes the driver.
# DATABASE_URL=postgres://user:password@host:5432/vectorflow

# ---- Auth (required in production) -----------------------------------------
# Require a valid login for the data endpoints (search / ask / ingest).
VFR_AUTH__REQUIRED=true

# JWT signing secret. Generate a long random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# (render.yaml asks Render to generate this for you automatically.)
VFR_AUTH__JWT_SECRET=replace-with-a-long-random-string

# Public URL of THIS backend. Used to build the OAuth callback URLs and to
# decide whether the OAuth state cookie is marked Secure (https => Secure).
VFR_AUTH__PUBLIC_BASE_URL=https://vectorflow-api.onrender.com

# Where users land after a successful OAuth login — your Vercel frontend.
VFR_AUTH__FRONTEND_URL=https://vectorflow.vercel.app

# ---- CORS ------------------------------------------------------------------
# JSON array of allowed browser origins. Must list your frontend EXACTLY
# (scheme + host, no trailing slash). Add preview domains if you use them.
VFR_API__CORS_ORIGINS=["https://vectorflow.vercel.app"]

# ---- OAuth (optional — email/password works without these) -----------------
# Google  ▸ https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI:
#   https://vectorflow-api.onrender.com/api/v1/auth/google/callback
# VFR_AUTH__GOOGLE_CLIENT_ID=
# VFR_AUTH__GOOGLE_CLIENT_SECRET=
#
# GitHub  ▸ https://github.com/settings/developers  (New OAuth App)
#   Authorization callback URL:
#   https://vectorflow-api.onrender.com/api/v1/auth/github/callback
# VFR_AUTH__GITHUB_CLIENT_ID=
# VFR_AUTH__GITHUB_CLIENT_SECRET=

# ---- Provider API-key encryption (optional, recommended) -------------------
# A Fernet key so the LLM-provider API keys you enter in the Settings UI are
# encrypted at rest AND survive across instances/redeploys. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# VFR_SECRET_KEY=

# ---- Password-reset email (optional) ---------------------------------------
# Without SMTP configured, reset links are written to the logs instead of
# emailed (fine for a demo). To actually send mail, set all five:
# VFR_AUTH__SMTP_HOST=smtp.example.com
# VFR_AUTH__SMTP_PORT=587
# VFR_AUTH__SMTP_USER=apikey
# VFR_AUTH__SMTP_PASSWORD=
# VFR_AUTH__SMTP_FROM=VectorFlow <no-reply@yourdomain.com>

# ---- Logging ---------------------------------------------------------------
VFR_LOGGING__FORMAT=json
