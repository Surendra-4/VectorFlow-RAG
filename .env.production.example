# ===========================================================================
# Live BACKEND environment — self-hosted on your PC, published via Cloudflare
# Tunnel, with the Vercel frontend talking to it.
# ===========================================================================
# Copy this file to `.env` at the repo root on the machine that runs the
# backend, then fill in the values. `python -m src.api` auto-loads `.env`.
# `.env` is gitignored — your secrets stay on your machine.
#
# Variable naming: nested settings use the VFR_ prefix and a "__" delimiter,
# e.g. AuthSettings.jwt_secret  ->  VFR_AUTH__JWT_SECRET. See src/config.py.

# ---- Where the server listens (local only) ---------------------------------
# Keep this on localhost: only cloudflared (running on the same machine)
# connects to it. Cloudflare terminates TLS and forwards to here.
VFR_API__HOST=127.0.0.1
VFR_API__PORT=8000

# ---- Database (managed cloud Postgres) -------------------------------------
# Paste the connection string from Neon / Supabase / etc. The app accepts
# postgres:// and postgresql:// and normalizes the driver to psycopg2.
# Neon example (note the required sslmode):
#   postgresql://user:pass@ep-xxx-123.us-east-2.aws.neon.tech/vectorflow?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ---- Auth (required in production) -----------------------------------------
VFR_AUTH__REQUIRED=true

# JWT signing secret. Generate a long random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
VFR_AUTH__JWT_SECRET=replace-with-a-long-random-string

# Public URL of THIS backend = your Cloudflare Tunnel hostname. Used to build
# the OAuth callback URLs and to mark the OAuth cookie Secure (https => Secure).
VFR_AUTH__PUBLIC_BASE_URL=https://api.yourdomain.com

# Where users land after a successful OAuth login — your Vercel frontend.
VFR_AUTH__FRONTEND_URL=https://vectorflow.vercel.app

# ---- CORS ------------------------------------------------------------------
# JSON array of allowed browser origins. Must list your frontend EXACTLY
# (scheme + host, no trailing slash). Add preview domains if you use them.
VFR_API__CORS_ORIGINS=["https://vectorflow.vercel.app"]

# ---- OAuth (optional — email/password works without these) -----------------
# Google  ▸ https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI:
#   https://api.yourdomain.com/api/v1/auth/google/callback
# VFR_AUTH__GOOGLE_CLIENT_ID=
# VFR_AUTH__GOOGLE_CLIENT_SECRET=
#
# GitHub  ▸ https://github.com/settings/developers  (New OAuth App)
#   Authorization callback URL:
#   https://api.yourdomain.com/api/v1/auth/github/callback
# VFR_AUTH__GITHUB_CLIENT_ID=
# VFR_AUTH__GITHUB_CLIENT_SECRET=

# ---- Provider API-key encryption (recommended) -----------------------------
# A Fernet key so the LLM-provider API keys you enter in the Settings UI are
# encrypted at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# VFR_SECRET_KEY=

# ---- Password-reset email (optional) ---------------------------------------
# Without SMTP configured, reset links are written to the logs instead of
# emailed (fine for a demo). To actually send mail, set all five:
# VFR_AUTH__SMTP_HOST=smtp.example.com
# VFR_AUTH__SMTP_PORT=587
# VFR_AUTH__SMTP_USER=apikey
# VFR_AUTH__SMTP_PASSWORD=
# VFR_AUTH__SMTP_FROM=VectorFlow <no-reply@yourdomain.com>

# ---- Logging ---------------------------------------------------------------
VFR_LOGGING__FORMAT=json
