# ===========================================================================
# Live BACKEND environment — FREE setup (₹0 recurring).
# Runs on your Mac, published through a free tunnel; Vercel frontend talks to it.
# ===========================================================================
# Copy to `.env` at the repo root on the machine that runs the backend, then
# fill in the values. `python -m src.api` auto-loads `.env`. `.env` is
# gitignored, so your secrets stay on your machine.
#
# Naming: nested settings use the VFR_ prefix and "__", e.g.
# AuthSettings.jwt_secret -> VFR_AUTH__JWT_SECRET. See src/config.py.

# ---- Where the server listens (local only) ---------------------------------
# Keep this on localhost — only the tunnel agent (same machine) connects to it.
VFR_API__HOST=127.0.0.1
VFR_API__PORT=8000

# ---- Database (free-tier cloud Postgres — no credit card) ------------------
# Neon (neon.tech) and Supabase (supabase.com) both have free tiers with no
# card required. Paste the connection string here; keep ?sslmode=require.
#   Neon example:
#   postgresql://user:pass@ep-xxx-123.us-east-2.aws.neon.tech/vectorflow?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# (Zero-account alternative: leave DATABASE_URL unset to use a local SQLite
#  file at ./var/app.db — durable on your Mac, no signup at all.)

# ---- Auth (required in production) -----------------------------------------
VFR_AUTH__REQUIRED=true

# Generate once:  python -c "import secrets; print(secrets.token_urlsafe(48))"
VFR_AUTH__JWT_SECRET=replace-with-a-long-random-string

# Public URL of THIS backend = your tunnel URL. Used to build the OAuth
# callback URLs and to mark the OAuth cookie Secure (https => Secure).
#   • ngrok static domain (STABLE — recommended): set this ONCE.
#     VFR_AUTH__PUBLIC_BASE_URL=https://your-name.ngrok-free.app
#   • Cloudflare Quick Tunnel (EPHEMERAL): update this EVERY session to the new
#     https://<random>.trycloudflare.com that `cloudflared` prints.
VFR_AUTH__PUBLIC_BASE_URL=https://your-name.ngrok-free.app

# Where users land after OAuth login — your (stable) Vercel URL.
VFR_AUTH__FRONTEND_URL=https://vectorflow.vercel.app

# ---- CORS ------------------------------------------------------------------
# Allowed BROWSER origins = your frontend. This is the Vercel URL (stable) —
# it does NOT change when the tunnel URL changes. JSON array, no trailing slash.
VFR_API__CORS_ORIGINS=["https://vectorflow.vercel.app"]

# ---- OAuth (optional — email/password works without these) -----------------
# Only practical with a STABLE tunnel URL (ngrok static domain): the redirect
# URI you register must match VFR_AUTH__PUBLIC_BASE_URL exactly. With an
# ephemeral quick-tunnel URL you'd have to re-register every session.
# Google  ▸ redirect URI: https://your-name.ngrok-free.app/api/v1/auth/google/callback
# VFR_AUTH__GOOGLE_CLIENT_ID=
# VFR_AUTH__GOOGLE_CLIENT_SECRET=
# GitHub  ▸ callback URL:  https://your-name.ngrok-free.app/api/v1/auth/github/callback
# VFR_AUTH__GITHUB_CLIENT_ID=
# VFR_AUTH__GITHUB_CLIENT_SECRET=

# ---- Provider API-key encryption (recommended) -----------------------------
# Encrypts the LLM-provider keys you enter in the Settings UI. Generate once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# VFR_SECRET_KEY=

# ---- Logging ---------------------------------------------------------------
VFR_LOGGING__FORMAT=json
