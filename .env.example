# VectorFlow-RAG environment overrides
#
# Copy this file to `.env` at the project root to override any defaults.
# Variables use the prefix VFR_ and the nested delimiter "__".
# All values are optional — anything you omit falls back to the defaults
# defined in src/config.py.

# ----- App ---------------------------------------------------------------- #
# VFR_APP__NAME=VectorFlow-RAG
# VFR_APP__VERSION=0.2.0-foundation

# ----- Embedder ----------------------------------------------------------- #
# VFR_EMBEDDER__MODEL_NAME=all-MiniLM-L6-v2
# VFR_EMBEDDER__DEVICE=cuda          # cuda | mps | cpu | (unset = auto)
# VFR_EMBEDDER__BATCH_SIZE=32
# VFR_EMBEDDER__NORMALIZE=true

# ----- Chunker ------------------------------------------------------------ #
# VFR_CHUNKER__CHUNK_SIZE=500
# VFR_CHUNKER__OVERLAP=50

# ----- Vector store ------------------------------------------------------- #
# VFR_VECTOR_STORE__BACKEND=chromadb # chromadb | faiss (faiss lands later)
# VFR_VECTOR_STORE__PERSIST_DIRECTORY=./indices/chroma_db
# VFR_VECTOR_STORE__COLLECTION_NAME=vectorflow_docs
# VFR_VECTOR_STORE__FAISS_INDEX_TYPE=hnsw
# VFR_VECTOR_STORE__FAISS_HNSW_M=32
# VFR_VECTOR_STORE__FAISS_HNSW_EF_CONSTRUCTION=200
# VFR_VECTOR_STORE__FAISS_HNSW_EF_SEARCH=64

# ----- BM25 --------------------------------------------------------------- #
# VFR_BM25__ENABLED=true
# VFR_BM25__LANGUAGE=english

# ----- LLM (Ollama) ------------------------------------------------------- #
# VFR_LLM__MODEL=tinyllama
# VFR_LLM__BASE_URL=http://localhost:11434
# VFR_LLM__MAX_TOKENS=512
# VFR_LLM__TEMPERATURE=0.7
# VFR_LLM__REQUEST_TIMEOUT_S=120

# ----- Retrieval ---------------------------------------------------------- #
# VFR_RETRIEVAL__K_DEFAULT=5
# VFR_RETRIEVAL__ALPHA=0.5
# VFR_RETRIEVAL__CANDIDATES_PER_MODALITY=10
# VFR_RETRIEVAL__RRF_K=60

# ----- Cache (Phase 6) ---------------------------------------------------- #
# VFR_CACHE__BACKEND=none            # none | memory | redis
# VFR_CACHE__REDIS_URL=redis://localhost:6379/0
# VFR_CACHE__TTL_SECONDS=3600        # default TTL when a namespace doesn't override
# VFR_CACHE__TTL_EMBEDDING_S=86400   # embeddings are content-keyed → safe to keep long
# VFR_CACHE__TTL_EXPANSION_S=86400   # expansion outputs cached → consistent repeat-query UX
# VFR_CACHE__TTL_RETRIEVAL_S=3600    # retrieval results, invalidated by corpus fingerprint

# ----- Observability (Phase 9) ------------------------------------------- #
# All metrics are process-local. Scrape via /api/v1/metrics/prometheus for
# multi-worker deployments. Defaults work for local-first dev; no env vars
# are strictly required.

# ----- Reranker (placeholder; cross-encoder lands later) ------------------ #
# VFR_RERANKER__ENABLED=false
# VFR_RERANKER__MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
# VFR_RERANKER__TOP_N=3
# VFR_RERANKER__DEVICE=

# ----- Logging ------------------------------------------------------------ #
# VFR_LOGGING__LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR
# VFR_LOGGING__FORMAT=text           # text | json
# VFR_LOGGING__FILE=./logs/vfr.log   # leave unset for stderr-only
# VFR_LOGGING__USE_COLOR=true

# ----- API (Phase 8) ------------------------------------------------------ #
# VFR_API__HOST=127.0.0.1
# VFR_API__PORT=8000
# VFR_API__RELOAD=false                          # set true for hot-reload during dev
# VFR_API__CORS_ORIGINS=["http://localhost:3000"]
#
# Run the server:
#   uvicorn --factory src.api.app:create_app --host 127.0.0.1 --port 8000
# Or for development with auto-reload:
#   uvicorn --factory src.api.app:create_app --reload --host 127.0.0.1 --port 8000

# ----- Ingestion (Phase 4) ------------------------------------------------ #
# VFR_INGESTION__MAX_FILE_SIZE_BYTES=104857600   # 100 MB default cap
# VFR_INGESTION__FAIL_FAST=false                 # collect failures; don't raise

# ----- Query Expansion (Phase 5) ----------------------------------------- #
# VFR_QUERY_EXPANSION__ENABLED=false             # off by default; adds 1-7s latency
# VFR_QUERY_EXPANSION__STRATEGIES=["multi_query","hyde"]
# VFR_QUERY_EXPANSION__MULTI_QUERY_COUNT=3       # number of LLM-generated variants
# VFR_QUERY_EXPANSION__HYDE_COUNT=1              # number of hypothetical docs
# VFR_QUERY_EXPANSION__TIMEOUT_S=10.0            # per-strategy wall-clock budget
# VFR_QUERY_EXPANSION__MAX_QUERY_LENGTH=500      # prompt-injection length cap
# VFR_QUERY_EXPANSION__MAX_VARIANT_LENGTH=1500   # per-variant length cap
# VFR_QUERY_EXPANSION__EXPANSION_MODEL=          # blank → use settings.llm.model
