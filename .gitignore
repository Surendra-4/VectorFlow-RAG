# .gitignore — VectorFlow-RAG
# (Note: .gitignore does not support trailing inline comments — keep comments
#  on their own lines, never after a pattern.)

# ── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
*.dist-info/
*.whl
.installed.cfg
# Packaging build dirs — anchored to the repo root with a leading slash so the
# bare names don't also match nested non-Python dirs like frontend/src/lib/.
/build/
/develop-eggs/
/dist/
/downloads/
/eggs/
/.eggs/
/lib/
/lib64/
/parts/
/sdist/
/wheels/

# ── Virtual environments ─────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Runtime state & local data (never committed) ─────────────────────────
# /var holds app.db, secrets.json (encrypted provider keys), runtime_config.json
/var/
# vector stores & named indexes (re-ingestable)
indices/*/
data/*/
*.db
*.sqlite3

# ── Secrets / local config ───────────────────────────────────────────────
# .env.example / .env.production.example are templates and ARE tracked.
.env
config.toml

# ── Testing ──────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Caches, logs, experiment tracking ────────────────────────────────────
.cache/
*.pkl
*.pickle
*.log
mlruns/
.mlflow/

# ── Jupyter ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Editors & OS ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Claude Code worktree metadata (local-only) ───────────────────────────
.claude/
